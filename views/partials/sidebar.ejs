<aside class="sidebar">

  <a href="/" class="logo">
    Daily Grove
  </a>

  <div class="sidebar-section">

    <p class="sidebar-label">
      Your Groves
    </p>

    <% users.forEach((user) => { %>

      <div class="user-item">

        <a
          href="/users/<%= user.id %>"
          class="user-link <%= currentUser && currentUser.id === user.id ? 'active' : '' %>"
        >

          <img
            class="avatar"
            src="<%= user.avatar_url %>"
            alt="<%= user.name %> avatar"
          >

          <span>
            <%= user.name %>'s Grove
          </span>

        </a>

        <a
          href="/users/<%= user.id %>/edit"
          class="edit-user-link"
        >
          ✎
        </a>

      </div>

    <% }) %>

  </div>

  <a href="/users/new" class="add-grove-card">

    <span class="add-grove-icon">
      +
    </span>

    <span>
      New Grove
    </span>

  </a>

</aside>