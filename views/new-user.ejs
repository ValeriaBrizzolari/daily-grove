<%- include("partials/header.ejs") %> <%- include("partials/sidebar.ejs") %>

<main class="page-main new-user-page">

  <section class="user-form-card">

    <h1>
      <%= locals.isEditing ? "Edit Your Grove" : "Create a New Grove" %>
    </h1>

    <p>
      <%= locals.isEditing
        ? "Update your grove name and avatar."
        : "Choose a name and a little companion for your grove." %>
    </p>

    <% if (locals.error) { %>
      <p class="form-error">
        <%= error %>
      </p>
    <% } %>

    <form
      action="<%= locals.isEditing ? `/users/${user.id}/edit` : '/users' %>"
      method="POST"
      class="user-form"
    >

      <label for="name">
        Grove Name
      </label>

      <input
        type="text"
        id="name"
        name="name"
        placeholder="Enter a name..."
        value="<%= locals.isEditing ? user.name : '' %>"
        required
      >

      <label>
        Choose an Avatar
      </label>

      <div class="avatar-options">

        <% const avatarSeeds = [
          "Milo",
          "Luna",
          "Cleo",
          "Willow",
          "Jasper",
          "Poppy",
          "Nora",
          "Theo"
        ]; %>

        <% avatarSeeds.forEach((seed) => { %>

          <label>

            <input
              type="radio"
              name="avatarSeed"
              value="<%= seed %>"

              <%= locals.isEditing &&
                  user.avatar_url.includes(`seed=${seed}`)
                    ? "checked"
                    : (!locals.isEditing && seed === "Milo")
                    ? "checked"
                    : ""
              %>
            >

            <img
              src="https://api.dicebear.com/9.x/lorelei/svg?seed=<%= seed %>"
              alt="<%= seed %> avatar"
            >

          </label>

        <% }) %>

      </div>

      <button
        type="submit"
        class="form-submit-btn"
      >
        <%= locals.isEditing ? "Save Changes" : "Create Grove" %>
      </button>

    </form>

  </section>

</main>
<%- include("partials/footer.ejs") %>